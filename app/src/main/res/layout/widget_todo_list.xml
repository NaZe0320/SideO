<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/widget_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/widget_card_background">

        <LinearLayout
            android:id="@+id/widget_header_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#2D3250" />

            <TextView
                android:id="@+id/widget_header_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textSize="10sp"
                android:textColor="#4C64FF"
                android:background="#E4E8FF"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/widget_add_button"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/widget_add_button_background"
                android:src="@drawable/ic_widget_add"
                android:contentDescription="@string/widget_add_todo"
                android:padding="6dp" />
        </LinearLayout>

        <ListView
            android:id="@+id/widget_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="4dp" />

        <TextView
            android:id="@+id/widget_empty_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widget_no_todos"
            android:textSize="12sp"
            android:textColor="#9EA1B1"
            android:gravity="center"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/widget_more_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical|end"
            android:paddingTop="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_more_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_more"
                android:textSize="11sp"
                android:textColor="#4C64FF" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
